# По умолчанию git сам определяет текст/бинарь и нормализует переводы строк.
* text=auto
# macOS bash-скрипты ДОЛЖНЫ быть с LF (CRLF ломает shebang).
*.sh text eol=lf
# Кроссплатформенные текстовые файлы — LF (bridge_agent.py и пр. бегут на mac).
*.py text eol=lf
*.js text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.plist text eol=lf
*.md text eol=lf
# Windows PowerShell — CRLF (BOM сохраняется git независимо от eol).
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
