# Скопируйте этот файл под именем .env и заполните значения.
# Файл .env — секретный: не выкладывайте его в интернет и не отправляйте никому.

# API-ключ вашего провайдера языковых моделей (см. README.md, где взять)
LLM_API_KEY=

# Адрес API. Оставьте пустым для официального OpenAI.
# Для других провайдеров впишите их base URL (пример есть в README.md)
LLM_BASE_URL=

# Название модели. Можно оставить пустым — тогда возьмётся gpt-4o-mini
LLM_MODEL=
