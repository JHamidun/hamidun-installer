{
  "name": "hamidun-installer",
  "productName": "Hamidun Setup",
  "version": "0.1.0",
  "description": "One-click installer for a fully configured Claude Code environment (Cursor, Claude Code, Git, Node.js, Hamidun config)",
  "author": "Zhemal Khamidun <hamidunjemal@gmail.com>",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "fetch:config": "node tools/fetch-config.js",
    "fetch:vendor": "powershell -ExecutionPolicy Bypass -NoProfile -File tools/fetch-vendor.ps1",
    "dist": "npm run fetch:config && npm run fetch:vendor && electron-builder",
    "dist:win": "npm run fetch:config && npm run fetch:vendor && electron-builder --win",
    "dist:win:lite": "npm run fetch:config && electron-builder --win",
    "dist:mac": "npm run fetch:config && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps",
    "test": "node test/run-tests.js"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.hamidun.setup",
    "productName": "Hamidun Setup",
    "directories": { "output": "release" },
    "files": [
      "src/**/*"
    ],
    "extraResources": [
      { "from": "scripts", "to": "scripts" },
      { "from": "agent", "to": "agent", "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc"] },
      { "from": "config.json", "to": "config.json" },
      { "from": "components.json", "to": "components.json" },
      { "from": "packs.json", "to": "packs.json" },
      { "from": "assets/starter-project", "to": "assets/starter-project" },
      { "from": "assets/START-HERE.html", "to": "assets/START-HERE.html" }
    ],
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "artifactName": "Hamidun-Setup-Windows.${ext}",
      "requestedExecutionLevel": "requireAdministrator",
      "extraResources": [
        { "from": "vendor", "to": "vendor" }
      ]
    },
    "portable": {
      "requestExecutionLevel": "admin",
      "artifactName": "Hamidun-Setup-Windows.${ext}"
    },
    "afterPack": "tools/mac-adhoc-sign.js",
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "category": "public.app-category.developer-tools",
      "artifactName": "Hamidun-Setup-Mac.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "contents": [
        { "x": 140, "y": 260 },
        { "x": 400, "y": 260, "type": "link", "path": "/Applications" },
        { "x": 270, "y": 110, "type": "file", "path": "assets/mac/ПРОЧТИ ЕСЛИ ПИШЕТ ПОВРЕЖДЕНО.txt" }
      ]
    }
  }
}
